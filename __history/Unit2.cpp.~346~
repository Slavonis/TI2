uint64_t __fastcall lfsr(uint64_t seed, int steps)
{
    const int n = 33;
    const int taps[] = { 32, 12 };

    uint64_t state = seed & ((1ULL << n) - 1);

    for (int i = 0; i < steps; i++) {
        int feedback = 0;
        for (int t : taps) {
            feedback ^= (state >> t) & 1;
        }

        int out = state & 1;
        state = (state << 1) | (static_cast<uint64_t>(feedback));
    }
    return state;
}
