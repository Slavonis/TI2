char* resizeArray(char* arr, int &currentCapacity)
{
    int newCapacity = currentCapacity * 2;
    char* newArr = new char[newCapacity];

    for (int i = 0; i < currentCapacity; i++) {
        newArr[i] = arr[i];
    }

    delete[] arr;
    currentCapacity = newCapacity;
    return newArr;
}
