void __fastcall TMainForm::readFileInput(
    std::ifstream &fileName, TObject* Sender)
{
    String binaryStr = "";
    char ch;
    int i = 0;
    size = 65535;
    src = new char[size];

    unsigned char byte;

    while (fileName.read(&ch, 1)) {
		if (i >= size) {
            src = resizeArray(src, size);
        } else {
            src[i] = ch;
        }
        i++;
    }
    size = i;
    for (int j = 0; j < 10; j++) {
        ch = src[j];
        for (int i = 7; i >= 0; i--) {
            binaryStr += ((ch >> i) & 1) ? "1" : "0";
        }
        binaryStr += " ";
    }
    binaryStr += "\n\n\n";
    for (int j = size - 10; j < size; j++) {
        ch = src[j];
        for (int i = 7; i >= 0; i--) {
            binaryStr += ((ch >> i) & 1) ? "1" : "0";
        }
        binaryStr += " ";
    }
    reSrcText->Lines->Text = binaryStr;
    fileName.close();
}
